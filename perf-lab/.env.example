# Copy to .env and adjust for your local or deployed demo environment.
# All three integration paths now run over HTTP/2.

# REST backend  -> HTTP/2 over TLS (Kestrel). Browser-ready.
VITE_REST_URL=https://localhost:8090

# gRPC-Web backend -> HTTP/2 over TLS (Kestrel/.NET, grpc-energy-price-dotnet).
# Same runtime as REST so gRPC-vs-REST is an apples-to-apples comparison.
VITE_GRPC_URL=https://localhost:5005

# Graftcode Gateway HTTP/2 endpoint (gg.exe --http2Server --http2Port 5001).
# NOTE: the gateway serves HTTP/2 CLEARTEXT (h2c), which browsers do NOT support.
# For native/non-browser clients use the h2c endpoint directly:
VITE_GRAFT_HTTP2_URL=http://localhost:5001
# For the browser perf-lab you must terminate TLS in front of the gateway
# (e.g. a caddy/nginx reverse proxy on https://localhost:5001 -> h2c :5001),
# or fall back to the gateway's WebSocket transport:
VITE_GRAFT_WS_URL=ws://localhost:5000/ws
